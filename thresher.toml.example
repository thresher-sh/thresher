# Thresher configuration
# Copy to thresher.toml in the project root to customize defaults.
# CLI flags override these values.

# AI model to use for analysis agents (e.g. "sonnet", "opus", "haiku")
model = "sonnet"

# Transitive dependency depth to scan
depth = 2

# Output directory for reports
output_dir = "./thresher-reports"

# Directory for scan logs (each run gets a timestamped file)
# log_dir = "./logs"

# Launch in tmux split-pane UI (scan + live logs). Set to true to enable.
tmux = false

[vm]
cpus = 4
memory = 8   # GB
disk = 30    # GB

# Agent max_turns precedence: named section -> [analysts] -> YAML default
# If [analysts] max_turns is set, every other agent (predep, adversarial,
# report_maker, synthesize) inherits that value unless they have their own
# explicit section. This lets you configure once for the simple case.

[analysts]
# Global max_turns for all analyst agents. Also acts as the fallback for
# every other agent below if they don't define their own section.
# max_turns = 100

# Per-analyst overrides by name. These take precedence over the global max_turns.
# Analyst names: paranoid, behaviorist, investigator, pentester-vulns,
#   pentester-appsurface, pentester-memory, infra-auditor, shadowcatcher
# [analysts.max_turns_by_name]
# paranoid = 60
# shadowcatcher = 80

[predep]
# Override max turns for the pre-dependency discovery agent.
# Falls back to [analysts] max_turns when unset, then to YAML default (15).
# max_turns = 50

[adversarial]
# Override max turns for the adversarial verification agent.
# Falls back to [analysts] max_turns when unset, then to YAML default (20).
# max_turns = 200

[report_maker]
# Override max turns for the report-maker agent (produces structured HTML data).
# Falls back to [analysts] max_turns when unset, then to YAML default (15).
# max_turns = 100

[synthesize]
# Override max turns for the synthesis agent (produces markdown reports).
# Falls back to [analysts] max_turns when unset, then to YAML default (75).
# max_turns = 150

[limits]
# Host boundary hardening limits. These control the maximum sizes of
# data allowed to cross the VM→host boundary during report retrieval.
# max_json_size_mb = 10    # Max JSON payload from VM (MB)
# max_file_size_mb = 50    # Max individual file in report copy (MB)
# max_copy_size_mb = 500   # Max total size of report copy (MB)
# max_stdout_mb = 50       # Max stdout from VM before kill (MB)
# max_concurrent_ssh = 8   # Max parallel SSH sessions to VM
