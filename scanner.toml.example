# Threat Scanner configuration
# Copy to scanner.toml in the project root to customize defaults.
# CLI flags override these values.

# AI model to use for analysis agents (e.g. "sonnet", "opus", "haiku")
model = "sonnet"

# Transitive dependency depth to scan
depth = 2

# Output directory for reports
output_dir = "./scan-results"

# Directory for scan logs (each run gets a timestamped file)
# log_dir = "./logs"

# Launch in tmux split-pane UI (scan + live logs). Set to false to disable.
tmux = true

[vm]
cpus = 4
memory = 8   # GB
disk = 20    # GB
